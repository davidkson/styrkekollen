{
  "display_information": {
    "name": "Styrkekollen Issues",
    "description": "Skapa GitHub issues från Slack",
    "background_color": "#0a0a1a"
  },
  "features": {
    "bot_user": {
      "display_name": "Styrkekollen Issues",
      "always_online": true
    }
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "channels:history",
        "chat:write"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://WORKER_URL_HERE.workers.dev/slack/events",
      "bot_events": [
        "message.channels"
      ]
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": false,
    "token_rotation_enabled": false
  }
}
